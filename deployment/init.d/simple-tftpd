#!/bin/sh
# SysV init script for simple-tftpd (delegates to systemd when available)
#
### BEGIN INIT INFO
# Provides:          simple-tftpd
# Required-Start:    $remote_fs $network $time
# Required-Stop:     $remote_fs $network $time
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Simple TFTP Daemon
# Description:       Lightweight TFTP server (RFC 1350)
### END INIT INFO

NAME=simple-tftpd
DAEMON=/usr/bin/simple-tftpd
CONFIG=/etc/simple-tftpd/simple-tftpd.conf
PIDFILE=/run/simple-tftpd/simple-tftpd.pid
RUNAS=simple-tftpd

. /lib/lsb/init-functions 2>/dev/null || . /etc/rc.d/init.d/functions 2>/dev/null || true

uses_systemd() {
    command -v systemctl >/dev/null 2>&1 \
        && [ -d /run/systemd/system ] \
        && systemctl cat "${NAME}.service" >/dev/null 2>&1
}

if [ ! -x "$DAEMON" ]; then
    echo "$DAEMON not found or not executable" >&2
    exit 1
fi
if [ ! -f "$CONFIG" ]; then
    echo "Config file not found: $CONFIG" >&2
    exit 1
fi

do_start() {
    if uses_systemd; then
        systemctl start "${NAME}.service"
        return $?
    fi

    mkdir -p "$(dirname "$PIDFILE")"

    if command -v start-stop-daemon >/dev/null 2>&1; then
        start-stop-daemon --start --quiet --oknodo --background --make-pidfile \
            --pidfile "$PIDFILE" --chuid "$RUNAS:$RUNAS" \
            --exec "$DAEMON" -- --foreground start --config "$CONFIG"
        return $?
    fi

    if command -v runuser >/dev/null 2>&1; then
        runuser -u "$RUNAS" -- "$DAEMON" --foreground start --config "$CONFIG" &
        echo $! >"$PIDFILE"
        return 0
    fi

    su -s /bin/sh "$RUNAS" -c "$DAEMON --foreground start --config $CONFIG" &
    echo $! >"$PIDFILE"
    return 0
}

do_stop() {
    if uses_systemd; then
        systemctl stop "${NAME}.service"
        return $?
    fi

    if command -v start-stop-daemon >/dev/null 2>&1; then
        start-stop-daemon --stop --quiet --retry=TERM/30/KILL/5 \
            --pidfile "$PIDFILE" --exec "$DAEMON" || true
        return 0
    fi

    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null || true
        rm -f "$PIDFILE"
    fi
    pkill -x simple-tftpd 2>/dev/null || true
    return 0
}

case "$1" in
    start)
        log_daemon_msg "Starting $NAME" "$NAME" 2>/dev/null || echo "Starting $NAME..."
        do_start
        rc=$?
        log_end_msg "$rc" 2>/dev/null || { [ "$rc" -eq 0 ] || exit "$rc"; }
        ;;
    stop)
        log_daemon_msg "Stopping $NAME" "$NAME" 2>/dev/null || echo "Stopping $NAME..."
        do_stop
        rc=$?
        log_end_msg "$rc" 2>/dev/null || { [ "$rc" -eq 0 ] || exit "$rc"; }
        ;;
    restart|force-reload)
        do_stop
        do_start
        ;;
    status)
        if uses_systemd; then
            systemctl status "${NAME}.service" --no-pager
            exit $?
        fi
        if command -v status_of_proc >/dev/null 2>&1; then
            status_of_proc "$DAEMON" "$NAME" && exit 0 || exit $?
        fi
        if pgrep -x simple-tftpd >/dev/null 2>&1; then
            echo "$NAME is running"
            exit 0
        fi
        echo "$NAME is not running"
        exit 3
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|force-reload|status}" >&2
        exit 1
        ;;
esac

exit 0
